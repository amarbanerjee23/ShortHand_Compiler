Terminals unused in grammar

    ETOK
    WHILE


Grammar

    0 $accept: PROGRAMME_RULE $end

    1 PROGRAMME_RULE: DECLARATION_STATEMENT_LIST_RULE FUNCTION_LIST_RULE LOGIC_BLOCK

    2 FUNCTION_LIST_RULE: FUNCTION_LIST_RULE FUNCTION_RULE ';'
    3                   | ε

    4 FUNCTION_RULE: DEF ShortType IDENTIFIER '(' DECLARATION_STATEMENT_LIST_RULE ')' STATEMENT_BLOCK_RULE

    5 DECLARATION_STATEMENT_LIST_RULE: DECLARATION_STATEMENT_LIST_RULE DECLARATION_STATEMENT_RULE ';'
    6                                | DECLARATION_STATEMENT_RULE ';'

    7 ShortType: INT
    8          | FLOAT
    9          | DOUBLE
   10          | STRING
   11          | VOID
   12          | BOOL

   13 DECLARATION_STATEMENT_RULE: ShortType DECLARATION_VARIABLE_LIST_RULE

   14 DECLARATION_VARIABLE_LIST_RULE: DECLARATION_VARIABLE_LIST_RULE ',' IDENTIFIER
   15                               | DECLARATION_VARIABLE_LIST_RULE ',' IDENTIFIER '[' INT_LITERAL ']'
   16                               | IDENTIFIER
   17                               | IDENTIFIER '[' INT_LITERAL ']'
   18                               | ε

   19 LOGIC_BLOCK: STATEMENT_LIST_RULE

   20 STATEMENT_BLOCK_RULE: '{' STATEMENT_LIST_RULE '}'

   21 STATEMENT_LIST_RULE: STATEMENT_LIST_RULE STATEMENT_RULE
   22                    | STATEMENT_RULE

   23 STATEMENT_RULE: MODEL_DECLARATION
   24               | TENSOR_DECLARATION
   25               | GREENAI_CONTRACT
   26               | GREENAI_MEASUREMENT
   27               | INFER_STATEMENT
   28               | RETURN_STATEMENT
   29               | CONTINUE ';'
   30               | EXPRESSION_RULE ';'
   31               | VARIABLE_RULE '=' EXPRESSION_RULE ';'
   32               | IDENTIFIER '(' READ_VARIABLE_LIST_RULE ')' ';'
   33               | STATEMENT_BLOCK_RULE
   34               | IF EXPRESSION_RULE STATEMENT_BLOCK_RULE
   35               | IF EXPRESSION_RULE STATEMENT_BLOCK_RULE ELSE STATEMENT_BLOCK_RULE
   36               | LOOP VARIABLE_RULE '=' EXPRESSION_RULE ',' EXPRESSION_RULE STATEMENT_BLOCK_RULE
   37               | LOOP VARIABLE_RULE '=' EXPRESSION_RULE ',' EXPRESSION_RULE ',' EXPRESSION_RULE STATEMENT_BLOCK_RULE
   38               | LOOP EXPRESSION_RULE STATEMENT_BLOCK_RULE
   39               | GOTO IDENTIFIER ';'
   40               | GOTO IDENTIFIER IF EXPRESSION_RULE ';'
   41               | READ READ_VARIABLE_LIST_RULE ';'
   42               | BREAK ';'
   43               | PRINT PRINT_VARIABLE_LIST_RULE ';'
   44               | GREENAI_REPORT_RULE ';'
   45               | AI_INFER_RULE ';'
   46               | IDENTIFIER ':'
   47               | ';'

   48 RETURN_STATEMENT: RETURN EXPRESSION_RULE ';'
   49                 | RETURN ';'

   50 INFER_STATEMENT: INFER IDENTIFIER '(' IDENTIFIER ')' GREATER IDENTIFIER ';'

   51 TENSOR_DECLARATION: TENSOR IDENTIFIER PRECISION_NAME STRING_LITERAL ';'

   52 $@1: ε

   53 MODEL_DECLARATION: MODEL IDENTIFIER '{' $@1 MODEL_FIELD_LIST '}' ';'

   54 MODEL_FIELD_LIST: MODEL_FIELD_LIST MODEL_FIELD
   55                 | ε

   56 MODEL_FIELD: FORMAT FORMAT_NAME ';'
   57            | PATH STRING_LITERAL ';'
   58            | TASK STRING_LITERAL ';'
   59            | PRECISION PRECISION_NAME ';'
   60            | INPUT_SHAPE STRING_LITERAL ';'
   61            | OUTPUT_SHAPE STRING_LITERAL ';'
   62            | BACKEND_PREFERENCE BACKEND_LIST ';'
   63            | COMPACT TRUE ';'
   64            | COMPACT FALSE ';'
   65            | QUALITY_GUARDRAIL IDENTIFIER GREATER_OR_EQUAL INT_LITERAL ';'

   66 BACKEND_LIST: BACKEND_LIST ',' BACKEND_NAME
   67             | BACKEND_NAME

   68 $@2: ε

   69 GREENAI_CONTRACT: GREENAI_CONTRACT_T IDENTIFIER '{' $@2 CONTRACT_FIELD_LIST '}' ';'

   70 CONTRACT_FIELD_LIST: CONTRACT_FIELD_LIST CONTRACT_FIELD
   71                    | ε

   72 CONTRACT_FIELD: FUNCTIONAL_UNIT STRING_LITERAL ';'
   73               | SUCCESS_CRITERIA STRING_LITERAL ';'
   74               | BOUNDARY BOUNDARY_LIST ';'
   75               | MEASUREMENT_QUALITY MQ_NAME ';'
   76               | DATA_QUALITY DQ_NAME ';'
   77               | CARBON_FACTOR LOCATION INT_LITERAL ';'
   78               | ENERGY_BUDGET_J INT_LITERAL ';'
   79               | CARBON_BUDGET_GCO2E INT_LITERAL ';'
   80               | QUALITY_GUARDRAIL IDENTIFIER GREATER_OR_EQUAL INT_LITERAL ';'
   81               | EVIDENCE_RETENTION STRING_LITERAL ';'
   82               | CLAIMS_MODE EVIDENCE_ONLY ';'

   83 BOUNDARY_LIST: BOUNDARY_LIST ',' BOUNDARY_NAME
   84              | BOUNDARY_NAME

   85 $@3: ε

   86 GREENAI_MEASUREMENT: GREENAI_MEASURE IDENTIFIER '{' $@3 MEASURE_FIELD_LIST '}' ';'

   87 MEASURE_FIELD_LIST: MEASURE_FIELD_LIST MEASURE_FIELD
   88                   | ε

   89 MEASURE_FIELD: IDENTIFIER INT_LITERAL ';'
   90              | IDENTIFIER IDENTIFIER ';'

   91 FORMAT_NAME: ONNX
   92            | ENGINE
   93            | TORCHSCRIPT
   94            | OPENVINO_IR
   95            | GGUF

   96 PRECISION_NAME: INT8
   97               | INT4
   98               | FP16
   99               | FP32
  100               | BF16
  101               | FP64
  102               | FLOAT

  103 BACKEND_NAME: TENSORRT
  104             | ONNXRUNTIME_TENSORRT
  105             | ONNXRUNTIME_CUDA
  106             | ONNXRUNTIME_CPU
  107             | OPENVINO
  108             | LIBTORCH
  109             | LLAMACPP
  110             | FALLBACK

  111 MQ_NAME: MQ1
  112        | MQ2
  113        | MQ3
  114        | MQ4

  115 DQ_NAME: DQ1
  116        | DQ2
  117        | DQ3
  118        | DQ4

  119 BOUNDARY_NAME: COMPUTE
  120              | ACCELERATOR
  121              | STORAGE
  122              | NETWORK
  123              | CI_CD
  124              | THIRDPARTY

  125 AI_INFER_RULE: IDENTIFIER '(' STRING_LITERAL ',' STRING_LITERAL ',' STRING_LITERAL ')'

  126 GREENAI_REPORT_RULE: IDENTIFIER '(' STRING_LITERAL ',' EXPRESSION_RULE ',' EXPRESSION_RULE ',' EXPRESSION_RULE ')'

  127 EXPRESSION_RULE: EXPRESSION_RULE '+' EXPRESSION_RULE
  128                | EXPRESSION_RULE '-' EXPRESSION_RULE
  129                | EXPRESSION_RULE '*' EXPRESSION_RULE
  130                | EXPRESSION_RULE '/' EXPRESSION_RULE
  131                | EXPRESSION_RULE '%' EXPRESSION_RULE
  132                | EXPRESSION_RULE LESS EXPRESSION_RULE
  133                | EXPRESSION_RULE LESS_OR_EQUAL EXPRESSION_RULE
  134                | EXPRESSION_RULE GREATER EXPRESSION_RULE
  135                | EXPRESSION_RULE GREATER_OR_EQUAL EXPRESSION_RULE
  136                | EXPRESSION_RULE EQUAL EXPRESSION_RULE
  137                | EXPRESSION_RULE NOT_EQUAL EXPRESSION_RULE
  138                | EXPRESSION_RULE OR EXPRESSION_RULE
  139                | EXPRESSION_RULE AND EXPRESSION_RULE
  140                | '-' EXPRESSION_RULE
  141                | '(' EXPRESSION_RULE ')'
  142                | VARIABLE_RULE
  143                | INT_LITERAL
  144                | FLOAT_LITERAL
  145                | TRUE
  146                | FALSE

  147 VARIABLE_RULE: IDENTIFIER
  148              | IDENTIFIER '[' EXPRESSION_RULE ']'

  149 READ_VARIABLE_LIST_RULE: READ_VARIABLE_LIST_RULE ',' VARIABLE_RULE
  150                        | VARIABLE_RULE

  151 PRINT_VARIABLE_LIST_RULE: PRINT_VARIABLE_LIST_RULE ',' STRING_LITERAL
  152                         | PRINT_VARIABLE_LIST_RULE ',' EXPRESSION_RULE
  153                         | STRING_LITERAL
  154                         | EXPRESSION_RULE


