Terminals unused in grammar

    ETOK
    WHILE


Grammar

    0 $accept: PROGRAMME_RULE $end

    1 PROGRAMME_RULE: DECLARATION_STATEMENT_LIST_RULE FUNCTION_LIST_RULE LOGIC_BLOCK

    2 FUNCTION_LIST_RULE: FUNCTION_LIST_RULE FUNCTION_RULE ';'
    3                   | ε

    4 FUNCTION_RULE: DEF ShortType IDENTIFIER '(' DECLARATION_STATEMENT_LIST_RULE ')' STATEMENT_BLOCK_RULE

    5 DECLARATION_STATEMENT_LIST_RULE: DECLARATION_STATEMENT_LIST_RULE DECLARATION_STATEMENT_RULE ';'
    6                                | DECLARATION_STATEMENT_RULE ';'

    7 ShortType: INT
    8          | FLOAT
    9          | STRING
   10          | VOID
   11          | BOOL

   12 DECLARATION_STATEMENT_RULE: ShortType DECLARATION_VARIABLE_LIST_RULE

   13 DECLARATION_VARIABLE_LIST_RULE: DECLARATION_VARIABLE_LIST_RULE ',' IDENTIFIER
   14                               | DECLARATION_VARIABLE_LIST_RULE ',' IDENTIFIER '[' INT_LITERAL ']'
   15                               | IDENTIFIER
   16                               | IDENTIFIER '[' INT_LITERAL ']'
   17                               | ε

   18 LOGIC_BLOCK: STATEMENT_LIST_RULE

   19 STATEMENT_BLOCK_RULE: '{' STATEMENT_LIST_RULE '}'

   20 STATEMENT_LIST_RULE: STATEMENT_LIST_RULE STATEMENT_RULE
   21                    | STATEMENT_RULE

   22 STATEMENT_RULE: EXPRESSION_RULE ';'
   23               | VARIABLE_RULE '=' EXPRESSION_RULE ';'
   24               | IDENTIFIER '(' READ_VARIABLE_LIST_RULE ')' ';'
   25               | STATEMENT_BLOCK_RULE
   26               | IF EXPRESSION_RULE STATEMENT_BLOCK_RULE
   27               | IF EXPRESSION_RULE STATEMENT_BLOCK_RULE ELSE STATEMENT_BLOCK_RULE
   28               | LOOP VARIABLE_RULE '=' EXPRESSION_RULE ',' EXPRESSION_RULE STATEMENT_BLOCK_RULE
   29               | LOOP VARIABLE_RULE '=' EXPRESSION_RULE ',' EXPRESSION_RULE ',' EXPRESSION_RULE STATEMENT_BLOCK_RULE
   30               | LOOP EXPRESSION_RULE STATEMENT_BLOCK_RULE
   31               | GOTO IDENTIFIER ';'
   32               | GOTO IDENTIFIER IF EXPRESSION_RULE ';'
   33               | READ READ_VARIABLE_LIST_RULE ';'
   34               | BREAK
   35               | PRINT PRINT_VARIABLE_LIST_RULE ';'
   36               | GREENAI_REPORT_RULE ';'
   37               | AI_INFER_RULE ';'
   38               | IDENTIFIER ':'
   39               | ';'

   40 AI_INFER_RULE: IDENTIFIER '(' STRING_LITERAL ',' STRING_LITERAL ',' STRING_LITERAL ')'

   41 GREENAI_REPORT_RULE: IDENTIFIER '(' STRING_LITERAL ',' EXPRESSION_RULE ',' EXPRESSION_RULE ',' EXPRESSION_RULE ')'

   42 EXPRESSION_RULE: EXPRESSION_RULE '+' EXPRESSION_RULE
   43                | EXPRESSION_RULE '-' EXPRESSION_RULE
   44                | EXPRESSION_RULE '*' EXPRESSION_RULE
   45                | EXPRESSION_RULE '/' EXPRESSION_RULE
   46                | EXPRESSION_RULE '%' EXPRESSION_RULE
   47                | EXPRESSION_RULE LESS EXPRESSION_RULE
   48                | EXPRESSION_RULE LESS_OR_EQUAL EXPRESSION_RULE
   49                | EXPRESSION_RULE GREATER EXPRESSION_RULE
   50                | EXPRESSION_RULE GREATER_OR_EQUAL EXPRESSION_RULE
   51                | EXPRESSION_RULE EQUAL EXPRESSION_RULE
   52                | EXPRESSION_RULE NOT_EQUAL EXPRESSION_RULE
   53                | EXPRESSION_RULE OR EXPRESSION_RULE
   54                | EXPRESSION_RULE AND EXPRESSION_RULE
   55                | '-' EXPRESSION_RULE
   56                | '(' EXPRESSION_RULE ')'
   57                | VARIABLE_RULE
   58                | INT_LITERAL

   59 VARIABLE_RULE: IDENTIFIER
   60              | IDENTIFIER '[' EXPRESSION_RULE ']'

   61 READ_VARIABLE_LIST_RULE: READ_VARIABLE_LIST_RULE ',' VARIABLE_RULE
   62                        | VARIABLE_RULE

   63 PRINT_VARIABLE_LIST_RULE: PRINT_VARIABLE_LIST_RULE ',' STRING_LITERAL
   64                         | PRINT_VARIABLE_LIST_RULE ',' EXPRESSION_RULE
   65                         | STRING_LITERAL
   66                         | EXPRESSION_RULE


