Terminals unused in grammar

    ETOK
    WHILE


Grammar

    0 $accept: PROGRAMME_RULE $end

    1 PROGRAMME_RULE: DECLARATION_STATEMENT_LIST_RULE FUNCTION_LIST_RULE LOGIC_BLOCK

    2 FUNCTION_LIST_RULE: FUNCTION_LIST_RULE FUNCTION_RULE ';'
    3                   | ε

    4 FUNCTION_RULE: DEF ShortType IDENTIFIER '(' DECLARATION_STATEMENT_LIST_RULE ')' STATEMENT_BLOCK_RULE

    5 DECLARATION_STATEMENT_LIST_RULE: DECLARATION_STATEMENT_LIST_RULE DECLARATION_STATEMENT_RULE ';'
    6                                | DECLARATION_STATEMENT_RULE ';'

    7 ShortType: INT
    8          | FLOAT
    9          | DOUBLE
   10          | STRING
   11          | VOID
   12          | BOOL

   13 DECLARATION_STATEMENT_RULE: ShortType DECLARATION_VARIABLE_LIST_RULE

   14 DECLARATION_VARIABLE_LIST_RULE: DECLARATION_VARIABLE_LIST_RULE ',' IDENTIFIER
   15                               | DECLARATION_VARIABLE_LIST_RULE ',' IDENTIFIER '[' INT_LITERAL ']'
   16                               | IDENTIFIER
   17                               | IDENTIFIER '[' INT_LITERAL ']'
   18                               | ε

   19 LOGIC_BLOCK: STATEMENT_LIST_RULE

   20 STATEMENT_BLOCK_RULE: '{' STATEMENT_LIST_RULE '}'

   21 STATEMENT_LIST_RULE: STATEMENT_LIST_RULE STATEMENT_RULE
   22                    | STATEMENT_RULE

   23 STATEMENT_RULE: MODEL_DECLARATION
   24               | TENSOR_DECLARATION
   25               | GREENAI_CONTRACT
   26               | GREENAI_MEASUREMENT
   27               | INFER_STATEMENT
   28               | RETURN_STATEMENT
   29               | CONTINUE ';'
   30               | EXPRESSION_RULE ';'
   31               | VARIABLE_RULE '=' EXPRESSION_RULE ';'
   32               | IDENTIFIER '(' READ_VARIABLE_LIST_RULE ')' ';'
   33               | STATEMENT_BLOCK_RULE
   34               | IF EXPRESSION_RULE STATEMENT_BLOCK_RULE
   35               | IF EXPRESSION_RULE STATEMENT_BLOCK_RULE ELSE STATEMENT_BLOCK_RULE
   36               | LOOP VARIABLE_RULE '=' EXPRESSION_RULE ',' EXPRESSION_RULE STATEMENT_BLOCK_RULE
   37               | LOOP VARIABLE_RULE '=' EXPRESSION_RULE ',' EXPRESSION_RULE ',' EXPRESSION_RULE STATEMENT_BLOCK_RULE
   38               | LOOP EXPRESSION_RULE STATEMENT_BLOCK_RULE
   39               | GOTO IDENTIFIER ';'
   40               | GOTO IDENTIFIER IF EXPRESSION_RULE ';'
   41               | READ READ_VARIABLE_LIST_RULE ';'
   42               | BREAK ';'
   43               | PRINT PRINT_VARIABLE_LIST_RULE ';'
   44               | GREENAI_REPORT_RULE ';'
   45               | AI_INFER_RULE ';'
   46               | IDENTIFIER ':'
   47               | ';'

   48 RETURN_STATEMENT: RETURN EXPRESSION_RULE ';'
   49                 | RETURN ';'

   50 INFER_STATEMENT: INFER IDENTIFIER '(' IDENTIFIER ')' ARROW IDENTIFIER ';'
   51                | INFER IDENTIFIER '(' IDENTIFIER ')' GREATER IDENTIFIER ';'

   52 TENSOR_DECLARATION: TENSOR IDENTIFIER PRECISION_NAME STRING_LITERAL ';'

   53 $@1: ε

   54 MODEL_DECLARATION: MODEL IDENTIFIER '{' $@1 MODEL_FIELD_LIST '}' ';'

   55 MODEL_FIELD_LIST: MODEL_FIELD_LIST MODEL_FIELD
   56                 | ε

   57 MODEL_FIELD: FORMAT FORMAT_NAME ';'
   58            | PATH STRING_LITERAL ';'
   59            | TASK STRING_LITERAL ';'
   60            | PRECISION PRECISION_NAME ';'
   61            | INPUT_SHAPE STRING_LITERAL ';'
   62            | OUTPUT_SHAPE STRING_LITERAL ';'
   63            | BACKEND_PREFERENCE BACKEND_LIST ';'
   64            | COMPACT TRUE ';'
   65            | COMPACT FALSE ';'
   66            | QUALITY_GUARDRAIL IDENTIFIER GREATER_OR_EQUAL INT_LITERAL ';'

   67 BACKEND_LIST: BACKEND_LIST ',' BACKEND_NAME
   68             | BACKEND_NAME

   69 $@2: ε

   70 GREENAI_CONTRACT: GREENAI_CONTRACT_T IDENTIFIER '{' $@2 CONTRACT_FIELD_LIST '}' ';'

   71 CONTRACT_FIELD_LIST: CONTRACT_FIELD_LIST CONTRACT_FIELD
   72                    | ε

   73 CONTRACT_FIELD: FUNCTIONAL_UNIT STRING_LITERAL ';'
   74               | SUCCESS_CRITERIA STRING_LITERAL ';'
   75               | BOUNDARY BOUNDARY_LIST ';'
   76               | MEASUREMENT_QUALITY MQ_NAME ';'
   77               | DATA_QUALITY DQ_NAME ';'
   78               | CARBON_FACTOR LOCATION INT_LITERAL ';'
   79               | ENERGY_BUDGET_J INT_LITERAL ';'
   80               | CARBON_BUDGET_GCO2E INT_LITERAL ';'
   81               | QUALITY_GUARDRAIL IDENTIFIER GREATER_OR_EQUAL INT_LITERAL ';'
   82               | EVIDENCE_RETENTION STRING_LITERAL ';'
   83               | CLAIMS_MODE EVIDENCE_ONLY ';'

   84 BOUNDARY_LIST: BOUNDARY_LIST ',' BOUNDARY_NAME
   85              | BOUNDARY_NAME

   86 $@3: ε

   87 GREENAI_MEASUREMENT: GREENAI_MEASURE IDENTIFIER '{' $@3 MEASURE_FIELD_LIST '}' ';'

   88 MEASURE_FIELD_LIST: MEASURE_FIELD_LIST MEASURE_FIELD
   89                   | ε

   90 MEASURE_FIELD: IDENTIFIER INT_LITERAL ';'
   91              | IDENTIFIER IDENTIFIER ';'

   92 FORMAT_NAME: ONNX
   93            | ENGINE
   94            | TORCHSCRIPT
   95            | OPENVINO_IR
   96            | GGUF

   97 PRECISION_NAME: INT8
   98               | INT4
   99               | FP16
  100               | FP32
  101               | BF16
  102               | FP64
  103               | FLOAT

  104 BACKEND_NAME: TENSORRT
  105             | ONNXRUNTIME_TENSORRT
  106             | ONNXRUNTIME_CUDA
  107             | ONNXRUNTIME_CPU
  108             | OPENVINO
  109             | LIBTORCH
  110             | LLAMACPP
  111             | FALLBACK

  112 MQ_NAME: MQ1
  113        | MQ2
  114        | MQ3
  115        | MQ4

  116 DQ_NAME: DQ1
  117        | DQ2
  118        | DQ3
  119        | DQ4

  120 BOUNDARY_NAME: COMPUTE
  121              | ACCELERATOR
  122              | STORAGE
  123              | NETWORK
  124              | CI_CD
  125              | THIRDPARTY

  126 AI_INFER_RULE: IDENTIFIER '(' STRING_LITERAL ',' STRING_LITERAL ',' STRING_LITERAL ')'

  127 GREENAI_REPORT_RULE: IDENTIFIER '(' STRING_LITERAL ',' EXPRESSION_RULE ',' EXPRESSION_RULE ',' EXPRESSION_RULE ')'

  128 EXPRESSION_RULE: EXPRESSION_RULE '+' EXPRESSION_RULE
  129                | EXPRESSION_RULE '-' EXPRESSION_RULE
  130                | EXPRESSION_RULE '*' EXPRESSION_RULE
  131                | EXPRESSION_RULE '/' EXPRESSION_RULE
  132                | EXPRESSION_RULE '%' EXPRESSION_RULE
  133                | EXPRESSION_RULE LESS EXPRESSION_RULE
  134                | EXPRESSION_RULE LESS_OR_EQUAL EXPRESSION_RULE
  135                | EXPRESSION_RULE GREATER EXPRESSION_RULE
  136                | EXPRESSION_RULE GREATER_OR_EQUAL EXPRESSION_RULE
  137                | EXPRESSION_RULE EQUAL EXPRESSION_RULE
  138                | EXPRESSION_RULE NOT_EQUAL EXPRESSION_RULE
  139                | EXPRESSION_RULE OR EXPRESSION_RULE
  140                | EXPRESSION_RULE AND EXPRESSION_RULE
  141                | '-' EXPRESSION_RULE
  142                | '(' EXPRESSION_RULE ')'
  143                | VARIABLE_RULE
  144                | INT_LITERAL
  145                | FLOAT_LITERAL
  146                | TRUE
  147                | FALSE

  148 VARIABLE_RULE: IDENTIFIER
  149              | IDENTIFIER '[' EXPRESSION_RULE ']'

  150 READ_VARIABLE_LIST_RULE: READ_VARIABLE_LIST_RULE ',' VARIABLE_RULE
  151                        | VARIABLE_RULE

  152 PRINT_VARIABLE_LIST_RULE: PRINT_VARIABLE_LIST_RULE ',' STRING_LITERAL
  153                         | PRINT_VARIABLE_LIST_RULE ',' EXPRESSION_RULE
  154                         | STRING_LITERAL
  155                         | EXPRESSION_RULE


