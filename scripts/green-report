#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BIN="${ROOT_DIR}/Compiler_new_ws/Short_Hand/build/green_ai_tool"
if [[ ! -x "${BIN}" ]]; then
  make -C "${ROOT_DIR}/Compiler_new_ws/Short_Hand/src" green_ai_tool >/dev/null
fi
exec "${BIN}" report "$@"
